# ============================================================================
# Sandryne Boutique — environment variables
# Copy to .env.local for development. Add every variable to Vercel
# (Project > Settings > Environment Variables) for deployment.
# Never put real secrets in this file.
# ============================================================================

# --- Supabase (Dashboard > Settings > API) ----------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Heartland / Global Payments (Portico) ----------------------------------
# Sandbox: pkapi_cert_... / skapi_cert_...  Production: pkapi_prod_... / skapi_prod_...
NEXT_PUBLIC_HEARTLAND_PUBLIC_KEY=pkapi_cert_your_key
HEARTLAND_SECRET_KEY=skapi_cert_your_key

# Assigned by Heartland at certification. Use placeholders for sandbox.
HEARTLAND_DEVELOPER_ID=000000
HEARTLAND_VERSION_NUMBER=0000

# --- Heartland Retail POS (inventory source of truth) ------------------------
# Base URL: https://{subdomain}.retail.heartland.us/api
HEARTLAND_RETAIL_SUBDOMAIN=yourstore
HEARTLAND_RETAIL_API_TOKEN=your_retail_api_token
HEARTLAND_RETAIL_STATION_ID=0
HEARTLAND_RETAIL_LOCATION_ID=0
HEARTLAND_RETAIL_WEB_PAYMENT_TYPE=0

# Protects /api/cron/sync-heartland-inventory (Authorization: Bearer …).
# Generate with: openssl rand -hex 32
CRON_SECRET=generate_a_long_random_string

# --- React Bits Pro ----------------------------------------------------------
REACTBITS_LICENSE_KEY=your-react-bits-license-key

# --- Site --------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Demo / development ------------------------------------------------------
# Set to false for real authentication in production.
AUTH_BYPASS=false
