# ============================================================================
# Sandryne Boutique — environment variables
# Copy to .env.local for development. Add every variable to Vercel
# (Project > Settings > Environment Variables) for deployment.
# ============================================================================

# --- Supabase (Dashboard > Settings > API) ----------------------------------
# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# SECRET — server-only. Bypasses Row Level Security. Never expose client-side.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Heartland / Global Payments (developer.globalpayments.com) -------------
# Public key (pkapi_cert_... for sandbox, pkapi_prod_... for live).
# Used by the browser to render hosted card fields and tokenize cards.
NEXT_PUBLIC_HEARTLAND_PUBLIC_KEY=pkapi_cert_your_key

# SECRET key (skapi_cert_... / skapi_prod_...). Server-only, charges cards.
HEARTLAND_SECRET_KEY=skapi_cert_your_key

# --- React Bits Pro ----------------------------------------------------------
# Used at development time by the shadcn CLI to install components/blocks.
REACTBITS_LICENSE_KEY=your-react-bits-license-key

# --- Site --------------------------------------------------------------------
# Canonical site URL. Used for auth email redirects and metadata.
# Local: http://localhost:3000 — Production: https://sandryneboutique.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Demo / development ------------------------------------------------------
# Demo mode is ON by default (login gates skipped, requests treated as a demo admin).
# To enable REAL authentication, set this to false. Any other value keeps demo mode on.
AUTH_BYPASS=false
